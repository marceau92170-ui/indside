generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth (NextAuth) ----------

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  name            String?
  image           String?
  // RGPD mineurs
  parentEmail     String?
  parentConsentAt DateTime?
  // Abonnement
  plan             String  @default("free") // free | premium
  stripeCustomerId String? @unique

  createdAt DateTime @default(now())

  accounts     Account[]
  sessions     Session[]
  profile      PlayerProfile?
  programs     Program[]
  sessionLogs  SessionLog[]
  testResults  TestResult[]
  badges       Badge[]
  subscription Subscription?
  pushSubscriptions PushSubscription[]
  wellnessCheckins  WellnessCheckin[]
  matchLogs         MatchLog[]
  bodyMeasurements  BodyMeasurement[]
  painLogs          PainLog[]
  goals             Goal[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Journal de diagnostic temporaire (capture la dernière erreur d'auth).
model DebugLog {
  key       String   @id
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Profil joueur ----------

model PlayerProfile {
  id        String @id @default(cuid())
  userId    String @unique
  firstName String
  birthYear Int
  position  String // GB | DC | LAT | MDF | MOF | AIL | ATT
  levelType String // DISTRICT | REGIONAL | NATIONAL
  division  String // ex: D3, R2, U17 National
  region    String // clé de ligue (voir lib/constants)
  district  String? // libellé libre du district
  heightCm  Int
  weightKg  Int
  clubTrainingsPerWeek Int
  matchDay  Int? // 0 = dimanche ... 6 = samedi, null = pas de match
  equipment String[] // ballon | plots | mur | city | elastiques
  goal      String // vitesse | technique | physique | endurance | frappe | polyvalent
  weakness  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- Bibliothèque d'exercices (seed, jamais générée par l'IA) ----------

model Exercise {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String // technique | renforcement | explosivite | cardio | prevention | gardien
  emoji       String
  description String   @db.Text
  steps       String[] // étapes d'exécution
  mistakes    String   @db.Text // erreurs fréquentes
  breathing   String? // consigne de respiration
  equipment   String[] // ballon | plots | mur | elastiques | aucun
  smallSpaceFriendly Boolean @default(false) // faisable en espace réduit (balcon, hall, petite cour), sans terrain
  minAge      Int      @default(13)
  positions   String[] // vide = tous postes ; sinon postes prioritaires
  variantEasy String   @db.Text
  variantHard String   @db.Text
  durationMin Int      @default(5)
  isFree      Boolean  @default(false) // accessible en plan gratuit (10 exercices)
}

// ---------- Programme & séances ----------

model Program {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime // lundi de la semaine
  source    String   @default("ai") // ai | template
  summary   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // sert aussi au cooldown anti-spam de régénération manuelle

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions TrainingSession[]

  @@index([userId, weekStart])
}

model TrainingSession {
  id          String @id @default(cuid())
  programId   String
  dayOfWeek   Int // 0 = dimanche ... 6 = samedi
  title       String
  durationMin Int
  objective   String
  advice      String @db.Text
  blocks      Json // [{ exerciseId, sets, reps, rest, instruction }]
  order       Int    @default(0)

  program Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  logs    SessionLog[]
}

model SessionLog {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  status      String // done | skipped
  difficulty  Int? // 1..5
  completedAt DateTime @default(now())

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId, completedAt])
}

// ---------- Tests d'évaluation ----------

model TestResult {
  id        String   @id @default(cuid())
  userId    String
  testType  String // jonglage | navette | planche | detente
  value     Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, testType, createdAt])
}

// ---------- Notifications push (en plus des e-mails de rappel) ----------

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- Gamification ----------

model Badge {
  id       String   @id @default(cuid())
  userId   String
  key      String // first_session | serie_3 | serie_7 | sessions_10 | sessions_25 | first_test | test_progress
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ---------- Abonnement ----------

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeSubscriptionId String    @unique
  status               String // active | trialing | past_due | canceled
  priceId              String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- Progresser vers le pro : suivi au-delà des séances ----------

// Check-in de forme quotidien (façon questionnaire de bien-être utilisé en pro) :
// sommeil, énergie, courbatures, humeur. Un par jour et par joueur.
model WellnessCheckin {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime // jour normalisé à minuit UTC (clé de dédoublonnage)
  sleepHours   Float?
  sleepQuality Int // 1-5
  energy       Int // 1-5
  soreness     Int // 1-5 (courbatures ressenties, 5 = beaucoup)
  mood         Int // 1-5
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// Carnet de match : la trace longitudinale de la progression en match réel.
model MatchLog {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime
  opponent      String?
  competition   String?
  minutesPlayed Int?
  goals         Int      @default(0)
  assists       Int      @default(0)
  rating        Int? // ressenti perso /10
  note          String?  @db.Text
  focusNext     String?  @db.Text // "un truc à travailler la prochaine fois"
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// Suivi de croissance : taille/poids dans le temps (utile en pleine puberté,
// distinct des valeurs statiques saisies à l'inscription).
model BodyMeasurement {
  id       String   @id @default(cuid())
  userId   String
  date     DateTime @default(now())
  heightCm Float
  weightKg Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// Carnet de douleurs/gênes — repérer une récidive avant qu'elle devienne une blessure.
model PainLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  bodyPart  String
  intensity Int // 1-5
  note      String?  @db.Text
  resolved  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// Objectifs personnels (au-delà du programme hebdo).
model Goal {
  id         String    @id @default(cuid())
  userId     String
  title      String
  targetDate DateTime?
  done       Boolean   @default(false)
  doneAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
