generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Retour utilisateurs (idées / bugs / avis) ----------

model Feedback {
  id        String   @id @default(cuid())
  userId    String? // rempli si connecté
  email     String? // email de contact laissé par la personne (facultatif)
  message   String   @db.Text
  page      String? // page depuis laquelle l'avis a été envoyé
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ---------- Auth (NextAuth) ----------

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  clerkId         String?   @unique // identifiant Clerk (rempli à la 1ère connexion Clerk)
  emailVerified   DateTime?
  name            String?
  image           String?
  // RGPD mineurs
  parentEmail     String?
  parentConsentAt DateTime?
  // Abonnement
  plan             String    @default("free") // free | premium
  stripeCustomerId String?   @unique
  premiumUntil     DateTime? // Premium offert (parrainage), hors Stripe
  hasUsedTrial     Boolean   @default(false) // a déjà consommé son essai gratuit 7 j (anti re-farming, 1×/compte)

  // Affiliation (créateurs externes)
  role            String  @default("user") // user | affiliate | admin
  referredByCode  String? // code de l'affilié attribué (premier lien gagné, gravé à vie)

  // Parrainage entre joueurs
  inviteCode          String?  @unique // code perso à partager avec ses coéquipiers
  invitedByCode       String? // code du pote qui l'a invité (gravé une fois)
  inviteRewardGranted Boolean  @default(false) // récompense d'inscription déjà versée au parrain ?
  paidInviteRewardGranted Boolean @default(false) // récompense "filleul abonné" déjà versée (1x, au 1er paiement) ?

  createdAt DateTime @default(now())

  accounts     Account[]
  sessions     Session[]
  profile      PlayerProfile?
  programs     Program[]
  sessionLogs  SessionLog[]
  testResults  TestResult[]
  badges       Badge[]
  subscription Subscription?
  pushSubscriptions PushSubscription[]
  wellnessCheckins  WellnessCheckin[]
  matchLogs         MatchLog[]
  bodyMeasurements  BodyMeasurement[]
  painLogs          PainLog[]
  goals             Goal[]
  affiliateProfile  Affiliate? @relation("AffiliateUser")
  emailEvents       EmailEvent[]
  review            Review?
}

// Journal des e-mails automatiques (bienvenue, relances nurture…).
// Garantit qu'on n'envoie jamais deux fois le même e-mail à un joueur.
model EmailEvent {
  id     String   @id @default(cuid())
  userId String
  key    String // welcome | nurture_d1 | nurture_d3
  sentAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ---------- Affiliation ----------

// Un affilié (créateur/influenceur) avec son lien de parrainage unique.
model Affiliate {
  id          String   @id @default(cuid())
  code        String   @unique // ex: "kevin" → progressafoot.fr/r/kevin
  displayName String
  email       String   @unique
  userId      String?  @unique // compte de connexion de l'affilié (pour son dashboard)
  isHouse     Boolean  @default(false) // lien "maison" (chaînes du créateur) : suivi sans commission
  promoStartsAt DateTime? // début du mois de lancement (1ère vidéo) : annuel à 80% pendant 30 j, 40% après. Si null → createdAt
  createdAt   DateTime @default(now())

  user        User?        @relation("AffiliateUser", fields: [userId], references: [id], onDelete: SetNull)
  commissions Commission[]
  clicks      LinkClick[]
  payouts     Payout[]
}

// Une commission = 80% du PREMIER paiement d'un joueur attribué à un affilié.
// Une seule par abonnement. Les renouvellements ne génèrent pas de commission.
model Commission {
  id                   String    @id @default(cuid())
  affiliateCode        String
  userId               String // le joueur qui a payé
  plan                 String // monthly | annual
  grossCents           Int // montant payé (centimes)
  commissionCents      Int // 80% du brut (centimes)
  stripeSubscriptionId String?  @unique // dédoublonnage : 1 commission par abonnement
  refunded             Boolean  @default(false)
  createdAt            DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateCode], references: [code], onDelete: Cascade)

  @@index([affiliateCode])
}

// Registre des versements manuels faits à un affilié (commission + bonus confondus).
// « Ce que tu lui dois » = tout ce qu'il a gagné (validé) − somme de ses versements.
model Payout {
  id            String   @id @default(cuid())
  affiliateCode String
  amountCents   Int
  note          String?
  createdAt     DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateCode], references: [code], onDelete: Cascade)

  @@index([affiliateCode])
}

// Un clic sur un lien de parrainage (pour le suivi côté affilié).
model LinkClick {
  id            String   @id @default(cuid())
  affiliateCode String
  createdAt     DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateCode], references: [code], onDelete: Cascade)

  @@index([affiliateCode, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Profil joueur ----------

model PlayerProfile {
  id        String @id @default(cuid())
  userId    String @unique
  firstName String
  birthYear Int
  position  String // GB | DC | LAT | MDF | MOF | AIL | ATT
  country   String @default("FR") // pays (francophonie) — FR garde le système FFF détaillé
  levelType String // DISTRICT | REGIONAL | NATIONAL | GENERIC (hors France)
  division  String // ex: D3, R2, U17 National, ou niveau générique hors France
  region    String // clé de ligue FFF (France) ou clé pays (hors France)
  district  String? // libellé libre du district (France) ou ville/région (hors France)
  heightCm  Int
  weightKg  Int
  clubTrainingsPerWeek Int
  matchDay  Int? // 0 = dimanche ... 6 = samedi, null = pas de match
  equipment String[] // ballon | plots | mur | city | elastiques
  goal      String // vitesse | technique | physique | endurance | frappe | polyvalent
  weakness  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- Bibliothèque d'exercices (seed, jamais générée par l'IA) ----------

model Exercise {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String // technique | renforcement | explosivite | cardio | prevention | gardien
  emoji       String
  description String   @db.Text
  steps       String[] // étapes d'exécution
  mistakes    String   @db.Text // erreurs fréquentes
  breathing   String? // consigne de respiration
  equipment   String[] // ballon | plots | mur | elastiques | aucun
  smallSpaceFriendly Boolean @default(false) // faisable en espace réduit (balcon, hall, petite cour), sans terrain
  minAge      Int      @default(13)
  positions   String[] // vide = tous postes ; sinon postes prioritaires
  variantEasy String   @db.Text
  variantHard String   @db.Text
  durationMin Int      @default(5)
  isFree      Boolean  @default(false) // accessible en plan gratuit (10 exercices)
}

// ---------- Programme & séances ----------

model Program {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime // lundi de la semaine
  source    String   @default("ai") // ai | template
  summary   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // sert aussi au cooldown anti-spam de régénération manuelle

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions TrainingSession[]

  @@index([userId, weekStart])
}

model TrainingSession {
  id          String @id @default(cuid())
  programId   String
  dayOfWeek   Int // 0 = dimanche ... 6 = samedi
  title       String
  durationMin Int
  objective   String
  advice      String @db.Text
  blocks      Json // [{ exerciseId, sets, reps, rest, instruction }]
  order       Int    @default(0)

  program Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  logs    SessionLog[]
}

model SessionLog {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  status      String // done | skipped
  difficulty  Int? // 1..5
  completedAt DateTime @default(now())

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId, completedAt])
}

// ---------- Tests d'évaluation ----------

model TestResult {
  id        String   @id @default(cuid())
  userId    String
  testType  String // jonglage | navette | planche | detente
  value     Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, testType, createdAt])
}

// ---------- Notifications push (en plus des e-mails de rappel) ----------

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- Gamification ----------

model Badge {
  id       String   @id @default(cuid())
  userId   String
  key      String // first_session | serie_3 | serie_7 | sessions_10 | sessions_25 | first_test | test_progress
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ---------- Abonnement ----------

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeSubscriptionId String    @unique
  status               String // active | trialing | past_due | canceled
  priceId              String?
  currentPeriodEnd     DateTime?
  trialEnd             DateTime? // fin de l'essai gratuit (si en essai)
  trialReminderSent    Boolean   @default(false) // mail « ton essai se termine » déjà envoyé ?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- Progresser vers le pro : suivi au-delà des séances ----------

// Check-in de forme quotidien (façon questionnaire de bien-être utilisé en pro) :
// sommeil, énergie, courbatures, humeur. Un par jour et par joueur.
model WellnessCheckin {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime // jour normalisé à minuit UTC (clé de dédoublonnage)
  sleepHours   Float?
  sleepQuality Int // 1-5
  energy       Int // 1-5
  soreness     Int // 1-5 (courbatures ressenties, 5 = beaucoup)
  mood         Int // 1-5
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// Carnet de match : la trace longitudinale de la progression en match réel.
model MatchLog {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime
  opponent      String?
  competition   String?
  minutesPlayed Int?
  goals         Int      @default(0)
  assists       Int      @default(0)
  rating        Int? // ressenti perso /10
  note          String?  @db.Text
  focusNext     String?  @db.Text // "un truc à travailler la prochaine fois"
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// Suivi de croissance : taille/poids dans le temps (utile en pleine puberté,
// distinct des valeurs statiques saisies à l'inscription).
model BodyMeasurement {
  id       String   @id @default(cuid())
  userId   String
  date     DateTime @default(now())
  heightCm Float
  weightKg Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// Carnet de douleurs/gênes — repérer une récidive avant qu'elle devienne une blessure.
model PainLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  bodyPart  String
  intensity Int // 1-5
  note      String?  @db.Text
  resolved  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// Objectifs personnels (au-delà du programme hebdo).
model Goal {
  id         String    @id @default(cuid())
  userId     String
  title      String
  targetDate DateTime?
  done       Boolean   @default(false)
  doneAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- Avis / témoignages (soumis par les utilisateurs, modérés) ----------
// UNIQUEMENT du vrai : un avis vient d'un utilisateur connecté, et n'est publié
// qu'après validation manuelle (status = approved). Un avis par utilisateur.
model Review {
  id          String   @id @default(cuid())
  userId      String   @unique
  rating      Int // 1 à 5
  text        String
  displayName String // prénom (pas de nom complet — RGPD mineurs)
  meta        String // ex : "Ailier · U16"
  status      String   @default("pending") // pending | approved | rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}
