generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  STARTER
  PRO
  AGENCY_PLUS
}

enum MailboxStatus {
  ACTIVE
  ERROR
  DISCONNECTED
}

enum EmailProvider {
  GMAIL
}

enum EmailCategory {
  LEAD_ACHAT
  LEAD_LOCATION
  DEMANDE_VISITE
  LOCATAIRE
  PROPRIETAIRE
  DOSSIER_PIECES
  FOURNISSEUR
  ADMIN
  SPAM
  AUTRE
}

enum Priority {
  URGENT
  NORMAL
  BAS
}

enum EmailStatus {
  NEW
  CLASSIFIED
  DRAFT_READY
  AUTO_SENT
  VALIDATED
  IGNORED
}

enum DraftStatus {
  PENDING
  APPROVED
  EDITED
  REJECTED
}

enum AutoAction {
  AUTO_REPLY
  DRAFT_ONLY
  LABEL_ONLY
}

model Agency {
  id               String    @id @default(cuid())
  name             String
  plan             Plan      @default(STARTER)
  stripeCustomerId String?   @unique
  stripeSubId      String?   @unique
  trialEndsAt      DateTime?
  tone             String    @default("vouvoiement")
  signature        String    @default("")
  emailQuotaUsed   Int       @default(0)
  emailQuotaMax    Int       @default(500)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  users           User[]
  mailboxes       Mailbox[]
  automationRules AutomationRule[]
  usageLogs       UsageLog[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  emailVerified DateTime?
  image         String?
  agencyId      String
  agency        Agency    @relation(fields: [agencyId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Mailbox {
  id              String        @id @default(cuid())
  agencyId        String
  agency          Agency        @relation(fields: [agencyId], references: [id])
  email           String
  provider        EmailProvider @default(GMAIL)
  accessTokenEnc  String        @db.Text
  refreshTokenEnc String        @db.Text
  tokenExpiresAt  DateTime?
  historyId       String?
  status          MailboxStatus @default(ACTIVE)
  lastSyncAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  messages EmailMessage[]
}

model EmailMessage {
  id            String         @id @default(cuid())
  mailboxId     String
  mailbox       Mailbox        @relation(fields: [mailboxId], references: [id])
  providerId    String
  threadId      String?
  from          String
  subject       String
  snippet       String?
  bodyText      String?        @db.Text
  category      EmailCategory?
  priority      Priority?
  extractedData Json?
  confidence    Float?
  status        EmailStatus    @default(NEW)
  receivedAt    DateTime
  processedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  draft Draft?

  @@unique([mailboxId, providerId])
}

model Draft {
  id              String       @id @default(cuid())
  emailMessageId  String       @unique
  emailMessage    EmailMessage @relation(fields: [emailMessageId], references: [id])
  content         String       @db.Text
  editedContent   String?      @db.Text
  status          DraftStatus  @default(PENDING)
  providerDraftId String?
  sentAt          DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model AutomationRule {
  id        String        @id @default(cuid())
  agencyId  String
  agency    Agency        @relation(fields: [agencyId], references: [id])
  category  EmailCategory
  action    AutoAction    @default(DRAFT_ONLY)
  template  String?       @db.Text
  enabled   Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([agencyId, category])
}

model UsageLog {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id])
  type        String
  tokensIn    Int?
  tokensOut   Int?
  emailsCount Int?
  metadata    Json?
  createdAt   DateTime @default(now())
}
